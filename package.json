{
  "name": "budget-assistant-chat",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c green,cyan \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "vercel dev --listen 3000 --yes",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cookie": "^1.0.2",
    "groq-sdk": "^0.16.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "twilio": "^5.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "vercel": "^50.39.0",
    "vite": "^5.4.19"
  }
}
